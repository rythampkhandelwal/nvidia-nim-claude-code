# NVIDIA NIM Config
NVIDIA_NIM_API_KEY=""
NVIDIA_NIM_PROXY=""


# Model routing: every Claude request maps to one model.
# Format: provider_type/model/name
MODEL="nvidia_nim/qwen/qwen3-coder-480b-a35b-instruct"
ENABLE_MODEL_THINKING=true


# Provider limits
PROVIDER_RATE_LIMIT=40
PROVIDER_RATE_WINDOW=60
PROVIDER_MAX_CONCURRENCY=5


# HTTP client timeouts (seconds)
HTTP_READ_TIMEOUT=120
HTTP_WRITE_TIMEOUT=10
HTTP_CONNECT_TIMEOUT=10


# Server auth (Anthropic-style)
ANTHROPIC_AUTH_TOKEN="freecc"


# Claude Code workspace and CLI
CLAUDE_WORKSPACE="./agent_workspace"
ALLOWED_DIR=""
CLAUDE_CLI_BIN="claude"


# Local Anthropic web_search / web_fetch handling (performs outbound HTTP)
ENABLE_WEB_SERVER_TOOLS=true
WEB_FETCH_ALLOWED_SCHEMES=http,https
WEB_FETCH_ALLOW_PRIVATE_NETWORKS=false


# Diagnostics
LOG_RAW_API_PAYLOADS=false
LOG_RAW_SSE_EVENTS=false
LOG_API_ERROR_TRACEBACKS=false
LOG_RAW_CLI_DIAGNOSTICS=false
